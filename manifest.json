{
  "manifest_version": 3,
  "name": "Tablo Kanban",
  "version": "1.0.0",
  "description": "Bookmarks bar and Kanban board as new tab page",
  "action": {
    "default_popup": "views/newtab.html",
    "default_title": "Открыть Tablo Kanban"
  },
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "options_page": "views/options.html",
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
