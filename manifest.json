{
  "manifest_version": 3,
  "name": "Tablo Kanban",
  "version": "1.0.0",
  "description": "Bookmarks bar and Kanban board as new tab page",
  "chrome_url_overrides": {
    "newtab": "views/newtab.html"
  },
  "action": {
    "default_title": "Open Tablo Kanban"
  },
  "permissions": [
    "bookmarks",
    "storage",
    "identity"
  ],
  "oauth2": {
    "client_id": "YOUR_CLIENT_ID_HERE",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "key": "YOUR_EXTENSION_PUBLIC_KEY_HERE — see https://developer.chrome.com/docs/extensions/reference/manifest/key",
  "options_page": "views/options.html",
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
